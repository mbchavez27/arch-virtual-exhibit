---
import corruptedTv from "../../assets/exhibit-assets/corrupted_tv.png";
import warningMail from "../../assets/exhibit-assets/warning_mail.png";
import clock from "../../assets/exhibit-assets/clock.png";
import moveBackward from "../../assets/exhibit-assets/move_backward.png";
import corruptedBackground from "../../assets/corrupted_earth/corrupted_earth.png";
import glitchOverlay from "../../assets/corrupted_earth/glitch.png";
import Navbar from "../navbar/Navbar.astro";
---

<div class="about-section">
    <section
        class="about-intro"
        style={`--corrupted-background: url("${corruptedBackground.src}"); --glitch-overlay: url("${glitchOverlay.src}");`}
    >
        <Navbar />
        <div class="history_component">
            <img src={corruptedTv.src} alt="Corrupted TV" class="history_component__tv" />
            <p class="history_component__desc">
                History is about to repeat itself in the digital world.
            </p>
            <div class="history_component__btns">
                <a href="#context" class="history_component__btn">Proceed</a>
                <a href="#context" class="history_component__arrow-link">
                    <img src={moveBackward.src} alt="Down" class="history_component__arrow" />
                </a>
            </div>
        </div>
    </section>
    <div class="context_component" id="context">
        <img src={warningMail.src} alt="Warning" class="context_component__icon" />

        <p class="context_component__text">
            Decades ago, early computers faced the infamous "Y2K" bug because
            they only used two digits to store years, causing massive panic that
            the year 2000 would be misread as 1900 and break several systems
            globally that depend on time tracking. While a massive global effort
            fixed that issue, a remarkably similar problem is ticking away right
            now: the Y2K38 bug.
        </p>

        <p class="context_component__text">
            While a massive global effort fixed that issue, a remarkably similar
            problem is ticking away right now: the Y2K38 bug. Many modern systems
            track time by counting the exact seconds that have elapsed since
            January 1, 1970, storing this data in a <span class="highlight--pink">limited
            32-bit format</span>.
        </p>

        <p class="context_component__text">
            On January 19, 2038, at <span class="highlight--pink">exactly 03:14:07 UTC</span>,
            this digital counter will hit its <span class="highlight--red">absolute maximum
            capacity</span> and overflow into negative numbers, tricking computers
            into rolling back to the year 1901. Left unchecked, this data overflow
            could trigger severe system malfunctions in everything from bank
            calculations to critical software.
        </p>

        <img src={clock.src} alt="Clock" class="context_component__clock" />

        <p class="context_component__text">
            Fortunately, unlike the panic of the past, scientists and developers
            are already quietly working behind the scenes to upgrade systems and
            adopt 64-bit time tracking, ensuring our digital clock keeps ticking
            smoothly into the future. Click below to explore the interactive
            timeline and discover exactly how this impending digital reset unfolds.
        </p>
    </div>
</div>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;700&display=swap");

    .about-section {
        padding: 0;
        background: #050610;
    }

    .about-intro {
        position: relative;
        isolation: isolate;
        overflow: hidden;
        background-color: #260000;
        background-image: var(--corrupted-background);
        background-repeat: repeat;
        background-position: center top;
        background-size: 1440px 1024px;
        image-rendering: pixelated;
    }

    .about-intro::before,
    .about-intro::after {
        content: "";
        position: absolute;
        z-index: 0;
        inset: 0;
        pointer-events: none;
    }

    .about-intro::before {
        opacity: 0.52;
        mix-blend-mode: screen;
        background-image: var(--glitch-overlay);
        background-repeat: repeat;
        background-position: 6% 18%;
        background-size: 540px 405px;
        animation: about-glitch-drift 2.4s steps(6, end) infinite;
    }

    .about-intro::after {
        opacity: 0.34;
        mix-blend-mode: screen;
        background:
            repeating-linear-gradient(to bottom, transparent 0 9px, rgba(255, 0, 0, 0.28) 9px 11px),
            linear-gradient(90deg, transparent 9%, rgba(255, 0, 0, 0.18) 9% 14%, transparent 14% 78%, rgba(0, 216, 255, 0.12) 78% 80%, transparent 80%);
        animation: about-screen-tear 1.35s steps(5, end) infinite;
    }

    .about-intro :global(.navbar) {
        position: relative;
        z-index: 2;
    }

    .history_component {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 3rem 2rem 6rem;
        width: 100%;
        min-height: max(680px, calc(100svh - 108px));
    }

    .history_component__tv {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 600px;
        height: auto;
        image-rendering: pixelated;
        margin-bottom: 3rem;
        animation: tv-float 3s ease-in-out infinite, tv-glitch 4s steps(2) infinite;
    }

    @keyframes tv-float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-12px); }
    }

    @keyframes tv-glitch {
        0%, 90%, 100% { filter: none; }
        92% { filter: hue-rotate(90deg); transform: translate(3px, -12px); }
        94% { filter: hue-rotate(-90deg); transform: translate(-3px, -10px); }
        96% { filter: none; transform: translateY(-12px); }
    }

    @keyframes about-glitch-drift {
        0%, 100% { transform: translate(0); opacity: 0.42; }
        22% { transform: translate(12px, -5px); opacity: 0.62; }
        23% { transform: translate(-8px, 4px); opacity: 0.28; }
        54% { transform: translate(0); opacity: 0.48; }
        55% { transform: translate(18px, 2px); opacity: 0.68; }
        58% { transform: translate(-5px, -3px); opacity: 0.36; }
    }

    @keyframes about-screen-tear {
        0%, 100% { clip-path: inset(0); transform: translateX(0); }
        42% { clip-path: inset(12% 0 70%); transform: translateX(8px); }
        46% { clip-path: inset(58% 0 25%); transform: translateX(-11px); }
        50% { clip-path: inset(0); transform: translateX(0); }
    }

    .history_component__desc {
        position: relative;
        z-index: 2;
        font-family: "Pixelify Sans", monospace;
        font-size: clamp(1.4rem, 3vw, 2rem);
        color: #ffffff;
        max-width: 700px;
        margin: 0 0 3rem;
        line-height: 1.5;
        text-shadow: 2px 2px 0 #000;
    }

    .history_component__btns {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
    }

    .history_component__btn {
        border: none;
        background: transparent;
        box-shadow: none;
        color: #ffd94a;
        padding: 0;
        font-family: "Pixelify Sans", monospace;
        font-size: 1.8rem;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
        transition: opacity 0.15s ease;
    }

    .history_component__btn:hover {
        opacity: 0.8;
    }

    .history_component__arrow-link {
        display: block;
        cursor: pointer;
        transition: opacity 0.15s ease;
    }

    .history_component__arrow-link:hover {
        opacity: 0.8;
    }

    .history_component__arrow {
        width: 48px;
        height: auto;
        transform: rotate(-90deg);
        image-rendering: pixelated;
    }

    .context_component {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 8rem 2rem;
        width: 100%;
        background-color: #050610;
        background-image: url("../../assets/exhibit-assets/about_bg.png");
        background-repeat: repeat;
        background-position: center top;
        background-size: 1440px 1024px;
    }

    .context_component__icon {
        width: 100px;
        height: auto;
        image-rendering: pixelated;
        margin-bottom: 3rem;
    }

    .context_component__text {
        font-family: "Pixelify Sans", monospace;
        font-size: clamp(1rem, 1.8vw, 1.3rem);
        color: #ffffff;
        max-width: 700px;
        margin: 0 auto 2rem;
        line-height: 1.8;
        text-shadow: 1px 1px 0 #000;
    }

    .highlight--pink {
        color: #FF00C8;
    }

    .highlight--red {
        color: #ff4444;
    }

    .context_component__clock {
        width: 160px;
        height: auto;
        image-rendering: pixelated;
        margin: 3rem auto;
    }

    @media (max-width: 640px) {
        .history_component {
            min-height: 680px;
            padding: 2rem 1.25rem 4rem;
        }

        .history_component__tv {
            margin-bottom: 2rem;
        }

        .context_component {
            padding: 5rem 1.25rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .about-intro::before,
        .about-intro::after,
        .history_component__tv {
            animation: none;
        }
    }
</style>
