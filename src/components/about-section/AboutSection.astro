---
import Navbar from "../navbar/Navbar.astro";

interface Props {
  content?: string;
}

const { content = "Coming soon..." } = Astro.props;
---

<div class="about-section">
    <Navbar />
    <h2>About</h2>
    <p>{content}</p>
    <slot />
</div>

<style>
    .about-section {
        padding: 2rem;
    }
</style>
