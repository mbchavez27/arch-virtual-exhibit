---
import corruptedTv from "../../assets/exhibit-assets/corrupted_tv.png";
import Navbar from "../navbar/Navbar.astro";
---

<section id="home" class="hero">
    <Navbar />
    <div class="hero__content">
        <img src={corruptedTv.src} alt="Corrupted TV" class="hero__tv" />
        <p class="hero__desc">
            History is about to repeat itself in the digital world.
        </p>
        <div class="hero__btns">
            <a href="#next" class="hero__btn hero__btn--proceed">Proceed</a>
            <span class="hero__arrow">&#9660;</span>
        </div>
    </div>
</section>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;700&display=swap");

    .hero {
        position: relative;
        width: 100%;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-image: url("../../assets/exhibit-assets/about_bg.png");
        background-size: cover;
        background-position: center;
    }

    .hero__content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
    }

    .hero__tv {
        width: 100%;
        max-width: 400px;
        height: auto;
        image-rendering: pixelated;
        margin-bottom: 2rem;
    }

    .hero__desc {
        font-family: "Pixelify Sans", monospace;
        font-size: clamp(1rem, 2vw, 1.4rem);
        color: #ffffff;
        text-align: center;
        max-width: 500px;
        margin: 0 0 2rem;
        line-height: 1.5;
        text-shadow: 2px 2px 0 #000;
    }

    .hero__btns {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
    }

    .hero__btn {
        display: block;
        text-align: center;
        padding: 0.6rem 2.25rem;
        font-family: "Pixelify Sans", monospace;
        font-size: 1.2rem;
        font-weight: 700;
        text-decoration: none;
        border: 3px solid #000;
        cursor: pointer;
        transition:
            transform 0.15s ease,
            box-shadow 0.15s ease;
    }

    .hero__btn--proceed {
        background: #ffd94a;
        color: #000;
        box-shadow: 4px 4px 0 #000;
    }

    .hero__btn--proceed:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 #000;
    }

    .hero__btn--proceed:active {
        transform: translate(2px, 2px);
        box-shadow: 2px 2px 0 #000;
    }

    .hero__arrow {
        color: #ffd94a;
        font-size: 1.5rem;
        display: block;
        text-align: center;
        text-shadow: 2px 2px 0 #000;
    }

    .hero :global(.navbar) {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 10;
    }

    @media (max-width: 640px) {
        .hero {
            min-height: 80vh;
            background-size: 100% auto;
        }
    }
</style>
