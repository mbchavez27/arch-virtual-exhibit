---
import tvScreen from "../../assets/exhibit-assets/tv_screen.png";
import logo from "../../assets/exhibit-assets/y2k38_logo.png";
---

<section id="home" class="hero">
    <div class="hero__content">
        <span class="hero__pretitle">Witness and Unravel the</span>
        <img src={logo.src} alt="Y2K38 Timeline" class="hero__logo" />
        <p class="hero__desc">
            Every computer on Earth is counting down to a single second in 2038.
            Push the timeline forward to see what happens when the digital clock
            runs out of space.
        </p>
        <div class="hero__btns">
            <a href="#home" class="hero__btn hero__btn--start">start</a>
            <a href={import.meta.env.BASE_URL} class="hero__btn hero__btn--quit"
                >quit</a
            >
        </div>
    </div>
</section>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;700&display=swap");

    .hero {
        position: relative;
        width: 100%;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-image: url("../../aVjssets/exhibit-assets/bg.png");
        background-size: cover;
        background-position: center;
    }

    .hero__content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
        width: 100%;
        max-width: 900px;
    }

    .hero__pretitle {
        font-family: "Pixelify Sans", monospace;
        font-size: clamp(1.2rem, 2.5vw, 1.8rem);
        color: #6fd7f7;
        margin: 0 0 0.5rem;
        letter-spacing: 0.05em;
    }

    .hero__logo {
        width: 100%;
        max-width: 600px;
        height: auto;
        margin-bottom: 0.25rem;
        image-rendering: pixelated;
    }

    .hero__desc {
        font-family: "Pixelify Sans", monospace;
        font-size: clamp(0.7rem, 1.2vw, 0.9rem);
        color: #e0d4f5;
        margin: 0 0 1rem;
        max-width: 500px;
        line-height: 1.5;
        text-shadow: 1px 1px 0 #000;
    }

    .hero__btns {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
        width: 100%;
        max-width: 120px;
    }

    .hero__btn {
        display: block;
        width: 100%;
        min-width: 80px;
        text-align: center;
        padding: 0.6rem 2.25rem;
        font-family: "Pixelify Sans", monospace;
        font-size: 1rem;
        font-weight: 700;
        text-transform: lowercase;
        text-decoration: none;
        border: 3px solid #000;
        cursor: pointer;
        transition:
            transform 0.15s ease,
            box-shadow 0.15s ease;
    }

    .hero__btn--start {
        background: #ffd94a;
        color: #fff;
        box-shadow: 4px 4px 0 #000;
    }

    .hero__btn--start:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 #000;
    }

    .hero__btn--start:active {
        transform: translate(2px, 2px);
        box-shadow: 2px 2px 0 #000;
    }

    .hero__btn--quit {
        background: #b0b8c4;
        color: #fff;
        box-shadow: 4px 4px 0 #000;
    }

    .hero__btn--quit:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 #000;
    }

    .hero__btn--quit:active {
        transform: translate(2px, 2px);
        box-shadow: 2px 2px 0 #000;
    }

    @media (max-width: 640px) {
        .hero {
            min-height: 80vh;
            background-size: cover;
        }
    }
</style>
