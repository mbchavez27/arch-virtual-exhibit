---
const START_UNSIGNED = 2147483636;
const OVERFLOW_UNSIGNED = 2147483648;
const MAX_UNSIGNED = 2147483660;
---

<div class="y2k38-info">
  <p id="warning" class="y2k38-info__warning hidden">⚠ WARNING: OVERFLOW INCOMING</p>
  <p id="negative-indicator" class="y2k38-info__negative hidden">⚠ EPOCH: NEGATIVE — TIME CORRUPTED</p>
  <p class="y2k38-info__line"><strong>UTC Time:</strong> <span id="utc-time">--</span></p>
  <p class="y2k38-info__line"><strong>PST Time:</strong> <span id="pst-time">--</span></p>
  <p class="y2k38-info__line"><strong>Unix Epoch:</strong> <span id="unix-epoch">--</span> seconds</p>
  <p class="y2k38-info__line"><strong>32-bit Binary:</strong> <span id="binary">--</span></p>

  <div class="y2k38-info__controls">
    <button id="play-btn" class="y2k38-info__btn">▶ play</button>
    <div class="y2k38-info__speeds">
      <button class="y2k38-info__speed active" data-speed="1">x1</button>
      <button class="y2k38-info__speed" data-speed="2">x2</button>
      <button class="y2k38-info__speed" data-speed="4">x4</button>
      <button class="y2k38-info__speed" data-speed="8">x8</button>
    </div>
  </div>

  <div class="y2k38-info__scrubber-container">
    <div id="scrubber-track" class="y2k38-info__track">
      <div id="scrubber-fill" class="y2k38-info__track-fill"></div>
      <div id="scrubber-thumb" class="y2k38-info__thumb"></div>
    </div>
  </div>
</div>

<script>
  const START_UNSIGNED = 2147483636;
  const OVERFLOW_UNSIGNED = 2147483648;
  const MAX_UNSIGNED = 2147483660;
  const GLITCH_DURATION = 5000;
  const TEASER_TICKS = 15;

  let unsignedEpoch = START_UNSIGNED;
  let playing = false;
  let timer: ReturnType<typeof setInterval> | null = null;
  let speed = 1;
  let isGlitching = false;
  let glitchTriggered = false;
  let wasPlayingBeforeGlitch = false;
  let resumingFromGlitch = false;

  const utcEl = document.getElementById('utc-time')!;
  const pstEl = document.getElementById('pst-time')!;
  const epochEl = document.getElementById('unix-epoch')!;
  const binaryEl = document.getElementById('binary')!;
  const playBtn = document.getElementById('play-btn')!;
  const container = document.querySelector('.y2k38-info')!;
  const track = document.getElementById('scrubber-track')!;
  const fill = document.getElementById('scrubber-fill')!;
  const thumb = document.getElementById('scrubber-thumb')!;
  const speedBtns = document.querySelectorAll('.y2k38-info__speed');
  const warningEl = document.getElementById('warning')!;
  const negativeEl = document.getElementById('negative-indicator')!;

  let warningShown = false;
  let isNegativeState = false;
  const WARNING_DURATION = 2000;

  function toSigned32(unsigned: number): number {
    if (unsigned > 2147483647) {
      return unsigned - 4294967296;
    }
    return unsigned;
  }

  function getProgress(): number {
    return ((unsignedEpoch - START_UNSIGNED) / (MAX_UNSIGNED - START_UNSIGNED)) * 100;
  }

  function getUTCTime(signed: number): string {
    return new Date(signed * 1000).toUTCString();
  }

  function getPSTTime(signed: number): string {
    const utcMs = signed * 1000;
    return new Date(utcMs - 8 * 60 * 60 * 1000).toUTCString();
  }

  function getBinary(unsigned: number): string {
    return (unsigned >>> 0).toString(2).padStart(32, '0');
  }

  function triggerGlitch() {
    if (glitchTriggered) return;
    glitchTriggered = true;
    isGlitching = true;

    container.classList.add('y2k38-info--glitch');
    document.dispatchEvent(new CustomEvent('y2k38-glitch-start'));

    setTimeout(() => {
      container.classList.remove('y2k38-info--glitch');
      document.dispatchEvent(new CustomEvent('y2k38-glitch-end'));
      isGlitching = false;
      if (wasPlayingBeforeGlitch) {
        resumingFromGlitch = true;
        startPlay();
      }
    }, GLITCH_DURATION);
  }

  function triggerTeaserGlitch() {
    container.classList.add('y2k38-info--teaser');
    document.dispatchEvent(new CustomEvent('y2k38-teaser'));
    setTimeout(() => {
      container.classList.remove('y2k38-info--teaser');
    }, 150);
  }

  function showWarning() {
    warningEl.classList.remove('hidden');
    setTimeout(() => {
      warningEl.classList.add('hidden');
    }, WARNING_DURATION);
  }

  function checkOverflow() {
    const signed = toSigned32(unsignedEpoch);
    
    if (unsignedEpoch >= OVERFLOW_UNSIGNED) {
      container.classList.add('y2k38-info--overflow');
      document.dispatchEvent(new CustomEvent('y2k38-overflow-start'));
      if (!glitchTriggered) {
        wasPlayingBeforeGlitch = playing;
        stopPlay();
        triggerGlitch();
      }
    } else {
      container.classList.remove('y2k38-info--overflow');
      document.dispatchEvent(new CustomEvent('y2k38-overflow-end'));
      glitchTriggered = false;
    }

    // Handle negative state (aftermath)
    if (signed < 0) {
      if (!isNegativeState) {
        isNegativeState = true;
        container.classList.add('y2k38-info--negative');
        negativeEl.classList.remove('hidden');
        document.dispatchEvent(new CustomEvent('y2k38-negative-start'));
      }
    } else {
      if (isNegativeState) {
        isNegativeState = false;
        container.classList.remove('y2k38-info--negative');
        negativeEl.classList.add('hidden');
        document.dispatchEvent(new CustomEvent('y2k38-negative-end'));
      }
    }
  }

  function updateDisplay() {
    const signed = toSigned32(unsignedEpoch);
    utcEl.textContent = getUTCTime(signed);
    pstEl.textContent = getPSTTime(signed);
    epochEl.textContent = signed.toLocaleString();
    binaryEl.textContent = getBinary(unsignedEpoch);
    fill.style.width = `${getProgress()}%`;
    thumb.style.left = `${getProgress()}%`;
    checkOverflow();
  }

  function tick() {
    if (unsignedEpoch < MAX_UNSIGNED) {
      unsignedEpoch++;
    } else {
      unsignedEpoch = START_UNSIGNED;
      warningShown = false;
    }

    if (unsignedEpoch === START_UNSIGNED && playing && !warningShown) {
      showWarning();
      warningShown = true;
    }

    updateDisplay();

    // Trigger teaser glitch before overflow
    const ticksUntilOverflow = OVERFLOW_UNSIGNED - unsignedEpoch;
    if (ticksUntilOverflow > 0 && ticksUntilOverflow <= TEASER_TICKS) {
      triggerTeaserGlitch();
    }
  }

  function startPlay() {
    if (isGlitching) return;
    playing = true;
    playBtn.textContent = '◼ stop';

    if (!warningShown && !resumingFromGlitch) {
      showWarning();
      warningShown = true;
    }
    resumingFromGlitch = false;

    timer = setInterval(tick, 1000 / speed);
  }

  function stopPlay() {
    playing = false;
    playBtn.textContent = '▶ play';
    if (timer) {
      clearInterval(timer);
      timer = null;
    }
  }

  function restartTimer() {
    if (playing && !isGlitching) {
      clearInterval(timer!);
      timer = setInterval(tick, 1000 / speed);
    }
  }

  function setEpochFromPosition(clientX: number) {
    const rect = track.getBoundingClientRect();
    const percent = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
    unsignedEpoch = Math.round(START_UNSIGNED + percent * (MAX_UNSIGNED - START_UNSIGNED));
    updateDisplay();
  }

  playBtn.addEventListener('click', () => {
    if (isGlitching) return;
    if (playing) {
      stopPlay();
    } else {
      startPlay();
    }
  });

  speedBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      speedBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      speed = parseInt(btn.getAttribute('data-speed') || '1');
      restartTimer();
    });
  });

  let isDragging = false;

  thumb.addEventListener('mousedown', (e) => {
    isDragging = true;
    e.preventDefault();
  });

  track.addEventListener('click', (e) => {
    stopPlay();
    setEpochFromPosition(e.clientX);
  });

  document.addEventListener('mousemove', (e) => {
    if (isDragging) {
      setEpochFromPosition(e.clientX);
    }
  });

  document.addEventListener('mouseup', () => {
    isDragging = false;
  });

  thumb.addEventListener('touchstart', (e) => {
    isDragging = true;
    e.preventDefault();
  });

  track.addEventListener('touchstart', (e) => {
    stopPlay();
    setEpochFromPosition(e.touches[0].clientX);
  });

  document.addEventListener('touchmove', (e) => {
    if (isDragging) {
      setEpochFromPosition(e.touches[0].clientX);
    }
  });

  document.addEventListener('touchend', () => {
    isDragging = false;
  });

  startPlay();
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;700&display=swap');

  @keyframes overflow-pulse {
    0%   { color: #ffffff; transform: scale(1); }
    50%  { color: #FFD94A; transform: scale(1.05); }
    100% { color: #ffffff; transform: scale(1); }
  }

  @keyframes glitch {
    0%   { transform: translate(0); filter: hue-rotate(0deg); }
    10%  { transform: translate(-3px, 2px); filter: hue-rotate(90deg); }
    20%  { transform: translate(3px, -2px); filter: hue-rotate(180deg); }
    30%  { transform: translate(-2px, -3px); filter: hue-rotate(270deg); }
    40%  { transform: translate(2px, 3px); filter: hue-rotate(360deg); }
    50%  { transform: translate(-3px, 0); filter: hue-rotate(90deg) brightness(1.5); }
    60%  { transform: translate(3px, 0); filter: hue-rotate(180deg); }
    70%  { transform: translate(0, -3px); filter: hue-rotate(270deg) brightness(2); }
    80%  { transform: translate(0, 3px); filter: hue-rotate(360deg); }
    90%  { transform: translate(-2px, 2px); filter: hue-rotate(90deg); }
    100% { transform: translate(0); filter: hue-rotate(0deg); }
  }

  @keyframes glitch-teaser {
    0%   { transform: translate(0); filter: hue-rotate(0deg); }
    25%  { transform: translate(-2px, 1px); filter: hue-rotate(45deg); }
    50%  { transform: translate(2px, -1px); filter: hue-rotate(90deg) brightness(1.3); }
    75%  { transform: translate(-1px, -2px); filter: hue-rotate(135deg); }
    100% { transform: translate(0); filter: hue-rotate(0deg); }
  }

  @keyframes warning-flash {
    0%   { opacity: 1; }
    50%  { opacity: 0.3; }
    100% { opacity: 1; }
  }

  .y2k38-info__warning {
    font-family: 'Pixelify Sans', monospace;
    font-size: clamp(0.9rem, 1.6vw, 1.2rem);
    color: #FF3333;
    margin: 0 0 0.25rem;
    text-shadow: 1px 0 #00FFFF, -1px 0 #FF00FF;
    animation: warning-flash 0.3s ease-out 3;
  }

  .y2k38-info__negative {
    font-family: 'Pixelify Sans', monospace;
    font-size: clamp(0.8rem, 1.4vw, 1rem);
    color: #ff6666;
    margin: 0 0 0.25rem;
    text-shadow: 1px 1px 0 #000;
    animation: negative-pulse 2s ease-in-out infinite;
  }

  @keyframes negative-pulse {
    0% { text-shadow: 1px 1px 0 #000; }
    50% { text-shadow: 1px 1px 0 #000, 0 0 8px rgba(255, 51, 51, 0.5); }
    100% { text-shadow: 1px 1px 0 #000; }
  }

  .hidden {
    display: none !important;
  }

  .y2k38-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
    align-items: center;
  }

  .y2k38-info--overflow .y2k38-info__line {
    animation: overflow-pulse 0.5s ease-out;
  }

  .y2k38-info--negative .y2k38-info__line {
    color: #ddd;
  }

  .y2k38-info--negative #unix-epoch {
    color: #ff6666;
    text-decoration: line-through;
    text-decoration-color: rgba(255, 102, 102, 0.6);
  }

  .y2k38-info--negative #utc-time,
  .y2k38-info--negative #pst-time {
    filter: saturate(0.7);
    color: #ccc;
  }

  .y2k38-info--glitch .y2k38-info__line {
    animation: glitch 0.3s infinite;
    color: #FF3333;
    text-shadow: 2px 0 #00FFFF, -2px 0 #FF00FF;
  }

  .y2k38-info--teaser .y2k38-info__line {
    animation: glitch-teaser 0.15s ease-out;
    color: #FF6666;
    text-shadow: 1px 0 #00FFFF, -1px 0 #FF00FF;
  }

  .y2k38-info__line {
    font-family: 'Pixelify Sans', monospace;
    font-size: clamp(0.8rem, 1.4vw, 1rem);
    color: #ffffff;
    margin: 0;
    text-shadow: 1px 1px 0 #000;
    transition: color 0.2s ease;
  }

  .y2k38-info__line strong {
    font-weight: 700;
  }

  .y2k38-info__controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .y2k38-info__btn {
    font-family: 'Pixelify Sans', monospace;
    font-size: 0.9rem;
    padding: 0.4rem 1rem;
    background: #FFD94A;
    color: #000;
    border: 2px solid #000;
    cursor: pointer;
    box-shadow: 2px 2px 0 #000;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }

  .y2k38-info__btn:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 #000;
  }

  .y2k38-info__btn:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #000;
  }

  .y2k38-info__speeds {
    display: flex;
    gap: 0.25rem;
  }

  .y2k38-info__speed {
    font-family: 'Pixelify Sans', monospace;
    font-size: 0.8rem;
    padding: 0.3rem 0.6rem;
    background: #1a1a2e;
    color: #ffffff;
    border: 2px solid #444;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .y2k38-info__speed:hover {
    border-color: #FFD94A;
  }

  .y2k38-info__speed.active {
    background: #FFD94A;
    color: #000;
    border-color: #000;
  }

  .y2k38-info__scrubber-container {
    width: 100%;
    max-width: 400px;
    margin-top: 0.75rem;
  }

  .y2k38-info__track {
    position: relative;
    width: 100%;
    height: 12px;
    background: #1a1a2e;
    border: 2px solid #444;
    cursor: pointer;
  }

  .y2k38-info__track-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: #FFD94A;
    width: 0%;
    pointer-events: none;
  }

  .y2k38-info__thumb {
    position: absolute;
    top: 50%;
    left: 0%;
    width: 16px;
    height: 16px;
    background: #FFD94A;
    border: 2px solid #000;
    border-radius: 0;
    transform: translate(-50%, -50%);
    cursor: grab;
    transition: transform 0.1s ease;
    z-index: 1;
  }

  .y2k38-info__thumb:hover {
    transform: translate(-50%, -50%) scale(1.2);
  }

  .y2k38-info__thumb:active {
    cursor: grabbing;
    transform: translate(-50%, -50%) scale(1.1);
  }

  @media (max-width: 640px) {
    .y2k38-info__controls {
      flex-direction: column;
    }

    .y2k38-info__btn,
    .y2k38-info__speed {
      min-height: 44px;
    }

    .y2k38-info__scrubber-container {
      max-width: 100%;
    }
  }
</style>
